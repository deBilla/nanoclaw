\documentclass[11pt,a4paper]{article}
\usepackage[T1]{fontenc}
\usepackage{lmodern}
\usepackage[top=0.75in,bottom=0.75in,left=0.75in,right=0.75in]{geometry}
\usepackage[hidelinks]{hyperref}
\usepackage{enumitem}
\usepackage{titlesec}
\usepackage{xcolor}
\usepackage{parskip}
\usepackage[most]{tcolorbox}

\definecolor{panel}{HTML}{1E3A5F}
\definecolor{paneltext}{HTML}{FFFFFF}
\definecolor{rule}{HTML}{1D4ED8}

\titleformat{\section}
  {\large\bfseries\color{rule}}{}{0em}{}
  [\vspace{-0.6ex}{\color{rule}\titlerule[0.6pt]}\vspace{0.4ex}]
\titlespacing*{\section}{0pt}{1.4ex}{0.3ex}

\setlist[itemize]{leftmargin=*,topsep=2pt,itemsep=1pt,parsep=0pt}

\pagestyle{empty}
\parskip=4pt

\begin{document}

%% ── Header: colored name panel (left) + contact block (right) ───────────────
\noindent
\begin{minipage}[t]{0.42\textwidth}
\begin{tcolorbox}[
  colback=panel, colframe=panel, coltext=paneltext,
  boxrule=0pt, arc=3pt, left=8pt, right=8pt, top=10pt, bottom=10pt,
  height=2.6cm, valign=center
]
  {\LARGE\bfseries\color{white} << personal.name >>}
\end{tcolorbox}
\end{minipage}%
\hfill
\begin{minipage}[t]{0.54\textwidth}
\vspace{4pt}
\small
\href{mailto:<< personal.email >>}{<< personal.email >>}\\
<% if personal.phone %><< personal.phone >>\\<% endif %>
<% if personal.location %><< personal.location >>\\<% endif %>
<% if personal.linkedin %>\href{<< personal.linkedin >>}{LinkedIn}<% if personal.github or personal.website %> \quad<% endif %><% endif %>%
<% if personal.github %>\href{<< personal.github >>}{GitHub}<% if personal.website %> \quad<% endif %><% endif %>%
<% if personal.website %>\href{<< personal.website >>}{<< personal.website >>}<% endif %>
\normalsize
\end{minipage}

\vspace{8pt}

<% if summary %>
\section{Summary}
<< summary >>
<% endif %>

<% if experience %>
\section{Experience}
<% for job in experience %>
\noindent\textbf{<< job.role >>}\hfill\textit{<< job.start >>} -- \textit{<< job.end or "Present" >>}\\[-2pt]
\textit{<< job.company >>}<% if job.location %>\hfill<< job.location >><% endif %>

<% if job.bullets %>
\begin{itemize}
<% for b in job.bullets %>  \item << b >>
<% endfor %>\end{itemize}
<% endif %>
<% if not loop.last %>\vspace{2pt}
<% endif %>
<% endfor %>
<% endif %>

<% if education %>
\section{Education}
<% for edu in education %>
\noindent\textbf{<< edu.institution >>}%
<% if edu.start or edu.end %>\hfill\textit{<% if edu.start %><< edu.start >><% endif %><% if edu.end %> -- << edu.end >><% endif %>}<% endif %>\\[-2pt]
\textit{<< edu.degree >><% if edu.field %>, << edu.field >><% endif %>}%
<% if edu.gpa %>\quad GPA:~<< edu.gpa >><% endif %>

<% endfor %>
<% endif %>

<% if skills %>
\section{Skills}
\begin{itemize}[label={},leftmargin=0pt,topsep=0pt,itemsep=2pt]
<% for category, items in skills.items() %>
  \item \textbf{<< category >>:}\enspace << items | join(", ") >>
<% endfor %>
\end{itemize}
<% endif %>

<% if projects %>
\section{Projects}
<% for proj in projects %>
\noindent\textbf{<< proj.name >>}%
<% if proj.url %>\enspace\href{<< proj.url >>}{\small[link]}<% endif %>%
<% if proj.tech %>\hfill\textit{\small << proj.tech | join(", ") >>}<% endif %>\\[-2pt]
<< proj.description >>

<% endfor %>
<% endif %>

\end{document}
